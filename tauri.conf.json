{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Geo Agents",
  "version": "0.1.0",
  "identifier": "com.geonexus.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Geo Agents",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["crates/geonexus-tauri/icons/icon.ico"],
    "resources": [
      "ai/sidecar.py",
      "ai/requirements.txt",
      "ai/web_search.py",
      "ai/geonexus_ai/**/*.py",
      "ai/context/**",
      "ai/docs/**",
      "ai/extractors/**/*.py",
      "ai/gis/**",
      "ai/graph/**/*.py",
      "ai/llm/**/*.py",
      "ai/memory/**",
      "ai/pipeline/**/*.py",
      "ai/recall/**/*.py"
    ]
  }
}
